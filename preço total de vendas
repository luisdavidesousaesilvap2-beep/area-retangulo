#preço total de vendas
valor = float(input("Digite o valor total da compra: "))

print("\nFormas de pagamento:")
print("1 - À vista (15% de desconto)")
print("2 - Cartão de débito (10% de desconto)")
print("3 - Cartão de crédito (5% de desconto)")

opcao = int(input("Escolha a forma de pagamento (1, 2 ou 3): "))

if opcao == 1:
    desconto = 0.15
elif opcao == 2:
    desconto = 0.10
elif opcao == 3:
    desconto = 0.05
else:
    print("Opção inválida")
    exit()

valor_final = valor - (valor * desconto)

print("Valor final a pagar: R$", valor_final)
